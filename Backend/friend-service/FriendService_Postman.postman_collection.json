{
    "info": {
        "_postman_id": "friend-service-collection",
        "name": "Friend Service API",
        "description": "Friend Service APIs through API Gateway with JWT Authentication",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{bearerToken}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8088/api-gateway/friend-service",
            "type": "string"
        },
        {
            "key": "bearerToken",
            "value": "",
            "type": "string",
            "description": "JWT Token from Keycloak"
        }
    ],
    "item": [
        {
            "name": "📋 SETUP - Get JWT Token First",
            "item": [
                {
                    "name": "Get Keycloak JWT Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "client_id",
                                    "value": "unicall-client"
                                },
                                {
                                    "key": "client_secret",
                                    "value": "BnaPyiYRiG0LP8sGdQNuCp1eZ32IFIya"
                                },
                                {
                                    "key": "grant_type",
                                    "value": "client_credentials"
                                }
                            ]
                        },
                        "url": {
                            "raw": "http://localhost:8080/realms/unicall/protocol/openid-connect/token",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8080",
                            "path": [
                                "realms",
                                "unicall",
                                "protocol",
                                "openid-connect",
                                "token"
                            ]
                        },
                        "description": "1. Send this request\n2. Copy 'access_token' from response\n3. Paste to {{bearerToken}} variable\n4. All requests will include Bearer token automatically"
                    }
                }
            ]
        },
        {
            "name": "Friend Endpoints",
            "item": [
                {
                    "name": "Get Friends by Account",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friends/idAccount/1?page=0&size=10&sortDirection=desc&name=",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friends",
                                "idAccount",
                                "1"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "10"
                                },
                                {
                                    "key": "sortDirection",
                                    "value": "desc"
                                },
                                {
                                    "key": "name",
                                    "value": ""
                                }
                            ]
                        },
                        "description": "Get all friends of account with ID {idAccount}"
                    }
                },
                {
                    "name": "Check Friendship Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friends/check-relationship/idAccountOrigin/1/idTarget/2",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friends",
                                "check-relationship",
                                "idAccountOrigin",
                                "1",
                                "idTarget",
                                "2"
                            ]
                        },
                        "description": "Check if two accounts are friends. Returns: areFriends, note, yourself"
                    }
                },
                {
                    "name": "Delete Friend",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friends/1",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friends",
                                "1"
                            ]
                        },
                        "description": "Delete a friend relationship by friend ID"
                    }
                }
            ]
        },
        {
            "name": "Friend Request Endpoints",
            "item": [
                {
                    "name": "Create Friend Request",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"idAccountSent\": 1,\n  \"idAccountReceive\": 2,\n  \"pathAvartar\": \"http://example.com/avatar.jpg\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friend-requestes",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friend-requestes"
                            ]
                        },
                        "description": "Create a new friend request from one account to another"
                    }
                },
                {
                    "name": "Update Friend Request Status",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friend-requestes/1/status",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friend-requestes",
                                "1",
                                "status"
                            ]
                        },
                        "description": "Update friend request status. Values: ACCEPTED, REJECTED, PENDING, CANCELLED"
                    }
                },
                {
                    "name": "Get Friend Requests by Receiver",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friend-requestes/account-receive/2?page=0&size=10&sortDirection=desc&name=",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friend-requestes",
                                "account-receive",
                                "2"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "10"
                                },
                                {
                                    "key": "sortDirection",
                                    "value": "desc"
                                },
                                {
                                    "key": "name",
                                    "value": ""
                                }
                            ]
                        },
                        "description": "Get all friend requests received by an account with pagination"
                    }
                },
                {
                    "name": "Get Friend Request Status",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/friend-requestes/status/idAccountSent/1/idAccountReceive/2",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "8088",
                            "path": [
                                "api-gateway",
                                "friend-service",
                                "api",
                                "v1",
                                "friend-requestes",
                                "status",
                                "idAccountSent",
                                "1",
                                "idAccountReceive",
                                "2"
                            ]
                        },
                        "description": "Check the status of a friend request between two accounts"
                    }
                }
            ]
        }
    ]
}