# UniCall global environment defaults
# Source: all application.yaml + Frontend/Mobile env fallbacks

# =========================
# Shared
# =========================
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka/
CORS_ALLOWED_ORIGINS=http://localhost:5173
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/unicall

# =========================
# Identity Service
# =========================
API_PREFIX=/api/v1
COOKIE_SECURE=false
COOKIE_SAME_SITE=Strict

KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=unicall
KEYCLOAK_CLIENT_ID=unicall-client
KEYCLOAK_CLIENT_SECRET=BnaPyiYRiG0LP8sGdQNuCp1eZ32IFIya
KEYCLOAK_ADMIN_CLIENT_ID=unicall-admin-client
KEYCLOAK_ADMIN_CLIENT_SECRET=qEtqS9STfjKuzU99109MTtlZfCcL8UBi
KEYCLOAK_ACTIVATION_EMAIL_LIFESPAN_SECONDS=86400

USER_SERVICE_GRPC_ADDRESS=static://localhost:9091
USER_SERVICE_GRPC_DEADLINE_MS=5000

# =========================
# User Service / File Service gRPC
# =========================
USER_SERVICE_GRPC_PORT=9091
FILE_SERVICE_GRPC_HOST=localhost
FILE_SERVICE_GRPC_PORT=9097
FILE_SERVICE_GRPC_DEADLINE_MS=5000

# =========================
# File Service
# =========================
FILE_MAX_SIZE=25MB
FILE_MAX_REQUEST_SIZE=30MB
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =========================
# Frontend (Vite)
# =========================
VITE_API_BASE_URL=http://localhost:8088/api-gateway
VITE_LOGIN_PATH=/login

# =========================
# Mobile (Expo)
# =========================
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_PORT=8088
EXPO_PUBLIC_API_GATEWAY_PATH=/api-gateway
EXPO_PUBLIC_LOGIN_PATH=/login
EXPO_PUBLIC_API_PREFIX=/api/v1

# =========================
# Docker compose defaults (optional)
# =========================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=unicall_user_service
MYSQL_USER=springstudent
MYSQL_PASSWORD=springstudent
