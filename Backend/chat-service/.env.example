AI_ASSISTANT_ENABLED=true

# Text AI (@Unicall) - Gemini
AI_ASSISTANT_API_KEY=your_gemini_key
AI_ASSISTANT_TEXT_MODEL=gemini-2.5-flash
AI_ASSISTANT_EMBEDDING_MODEL=text-embedding-004
AI_ASSISTANT_VECTOR_ENABLED=true
AI_ASSISTANT_VECTOR_CANDIDATE_LIMIT=120
AI_ASSISTANT_VECTOR_TOP_K=6
AI_ASSISTANT_VECTOR_MIN_TEXT_LENGTH=8
AI_ASSISTANT_VECTOR_MAX_NEW_EMBEDDINGS_PER_REQUEST=20
AI_ASSISTANT_VECTOR_MIN_SCORE=0.58
AI_ASSISTANT_VECTOR_INCLUDE_AI_MESSAGES=false

# Image AI (@UnicallImage): gemini | stability
AI_IMAGE_PROVIDER=stability

# Keep these when using Gemini image
AI_ASSISTANT_IMAGE_MODEL=gemini-2.5-flash-image

# Stability config (required when AI_IMAGE_PROVIDER=stability)
STABILITY_API_KEY=your_stability_key
STABILITY_BASE_URL=https://api.stability.ai
# stable-image-core | stable-image-ultra | sd3.5-large | sd3-large | ...
STABILITY_IMAGE_MODEL=stable-image-core
STABILITY_OUTPUT_FORMAT=png
