# Application
    SPRING_APPLICATION_NAME=profile

    # API
    API_PREFIX=/api/v1

    # Server
    SERVER_SERVLET_CONTEXT_PATH=/profile
    SERVER_PORT=8082

    # Datasource
    SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/profile_db?createDatabaseIfNotExist=true
    DB_USERNAME=springstudent
    DB_PASSWORD=springstudent
    SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

    # JPA
    SPRING_JPA_HIBERNATE_DDL_AUTO=update
    SPRING_JPA_SHOW_SQL=true
    SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect
    SPRING_JPA_OPEN_IN_VIEW=false